{
  "name": "rn-firebase-chat-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prepack": "turbo run prepack --filter=rn-firebase-chat",
    "release": "pnpm --filter=rn-firebase-chat release",
    "release:ci": "pnpm --filter=rn-firebase-chat release:ci",
    "release:check": "pnpm --filter=rn-firebase-chat release:check",
    "example": "pnpm -C apps/example",
    "example:web": "pnpm --filter=web-vite-example dev",
    "bootstrap": "pnpm install && pnpm -C apps/example"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "overrides": {
      "@types/react-native": "0.73.0",
      "@types/react": "~19.2.2"
    }
  },
  "engines": {
    "node": ">= 16.0.0"
  }
}

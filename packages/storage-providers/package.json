{
  "name": "@saigontechnology/chat-storage-providers",
  "version": "0.1.0",
  "description": "Storage provider implementations for rn-firebase-chat — Cloudinary and Firebase Storage, works on React Native and Web",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/index.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "../../node_modules/.bin/bob build",
    "typecheck": "../../node_modules/.bin/tsc --noEmit",
    "lint": "../../node_modules/.bin/eslint \"src/**/*.{ts,tsx}\""
  },
  "keywords": [
    "cloudinary",
    "firebase",
    "storage",
    "react-native",
    "chat",
    "file-upload",
    "typescript"
  ],
  "author": "SaiGon Technology",
  "license": "MIT",
  "dependencies": {
    "@saigontechnology/firebase-chat-shared": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@react-native-firebase/storage": "23.8.8",
    "@types/react": "^18.0.0",
    "eslint": "^9.30.0",
    "eslint-plugin-prettier": "^5.5.1",
    "firebase": "10.14.1",
    "prettier": "^3.6.2",
    "react-native-builder-bob": "0.40.12",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependencies": {
    "@react-native-firebase/storage": "*",
    "firebase": "*",
    "react": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-firebase/storage": {
      "optional": true
    },
    "firebase": {
      "optional": true
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      ["typescript", { "tsc": "../../node_modules/.bin/tsc" }]
    ]
  }
}

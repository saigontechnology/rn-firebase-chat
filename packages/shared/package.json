{
  "name": "@saigontechnology/firebase-chat-shared",
  "version": "0.1.0",
  "description": "Shared types, utilities, and business logic for react-firebase-chat and rn-firebase-chat",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/index.d.ts"
    },
    "./rnProvider": {
      "import": "./src/encryption/rnProvider.ts",
      "require": "./src/encryption/rnProvider.ts",
      "types": "./src/encryption/rnProvider.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest"
  },
  "keywords": [
    "firebase",
    "chat",
    "shared",
    "typescript"
  ],
  "author": "SaiGon Technology",
  "license": "MIT",
  "dependencies": {
    "dayjs": "^1.11.0"
  },
  "peerDependencies": {
    "react": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/react": "^18.0.0",
    "eslint": "^9.30.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}

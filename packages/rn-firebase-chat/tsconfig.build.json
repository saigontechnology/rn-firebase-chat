{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "isolatedModules": false,
    "noEmitOnError": false,
    "preserveSymlinks": true,
    "moduleResolution": "node",
    "jsx": "react",
    "target": "es2020",
    "module": "commonjs",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "rootDir": "./src",
    "outDir": "./lib",
    "declarationDir": "./lib/typescript",
    "removeComments": true,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "composite": false,
    "incremental": true,
    "tsBuildInfoFile": "./lib/.tsbuildinfo",
    "paths": {
      "@saigontechnology/firebase-chat-shared": [
        "../../packages/shared/lib/typescript/index.d.ts"
      ],
      "@saigontechnology/firebase-chat-shared/rnProvider": [
        "../../packages/shared/lib/typescript/encryption/rnProvider.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "example",
    "node_modules",
    "../../node_modules",
    "lib",
    "**/*.test.*",
    "**/__tests__/**",
    "**/*.spec.*",
    "**/jest.setup.*"
  ]
}
# Copy this file to .env and fill in your Firebase project values.
# Get these from Firebase Console → Project Settings → Your apps → Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary (used by CloudinaryStorageProvider for file uploads)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_FOLDER=chat
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_API_SECRET=

# ── Firebase Console setup required ──────────────────────────────────────────
#
# 1. Authentication → Sign-in method → Enable "Anonymous"
#    The example signs in anonymously so Firestore rules can check request.auth.
#
# 2. Firestore Database → Rules → publish the following:
#
#    rules_version = '2';
#    service cloud.firestore {
#      match /databases/{database}/documents {
#        match /{document=**} {
#          allow read, write: if request.auth != null;
#        }
#      }
#    }
#
# For production, tighten these rules to match your data model.

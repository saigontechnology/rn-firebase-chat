# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Firebase config (keep out of source control)
google-services.json
GoogleService-Info.plist

# typescript
*.tsbuildinfo

# generated native folders
/ios/build/*
/android/build/*
.kotlin/*
.gradle/*
.idea/*
.cxx/*
.cache/*
.expo-shared/*
